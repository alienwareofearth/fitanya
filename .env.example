# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ─── SESSION ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (Nodemailer + Brevo SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@email.com
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=noreply@fitanya.com
EMAIL_FROM_NAME=Fitanya

# ─── GOOGLE CALENDAR API ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://yourapp.com/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ─── PAYMENT MODE ────────────────────────────────────────────────────────────
# Options: personal | razorpay | phonepe
PAYMENT_MODE=personal

# ─── PERSONAL UPI (PAYMENT_MODE=personal) ────────────────────────────────────
UPI_ID=1234saahilsonkar@okaxis
UPI_PAYEE_NAME=Fitanya

# ─── RAZORPAY (PAYMENT_MODE=razorpay) ────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_optional

# ─── PHONEPE (PAYMENT_MODE=phonepe) ──────────────────────────────────────────
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT
# UAT = sandbox, PROD = production
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# ─── SMS GATEWAY ─────────────────────────────────────────────────────────────
SMS_GATEWAY_URL=https://your-sms-gateway.example.com
SMS_GATEWAY_TOKEN=your_gateway_token

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── APP ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_NAME=Fitanya
